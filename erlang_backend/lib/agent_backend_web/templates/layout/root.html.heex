<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="csrf-token" content={get_csrf_token()}/>
    <title><%= @page_title || "Agent Interface" %></title>
    <style><%= raw(app_css()) %></style>
    <script defer phx-track-static type="text/javascript" src={AgentBackendWeb.Endpoint.static_path("/assets/app.js")}></script>
  </head>
  <body class="h-full bg-zinc-950 text-zinc-200 font-sans antialiased">
    <%= @inner_content %>
  </body>
</html>
