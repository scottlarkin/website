<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="csrf-token" content={get_csrf_token()}/>
    <title><%= @page_title || "scott" %></title>
    <meta name="description" content={@meta_description || "Chat with an AI assistant about Scott's skills, experience, projects, and contact."} />
    <meta name="robots" content={@robots || "index,follow"} />
    <link rel="canonical" href={@canonical_url || AgentBackendWeb.Endpoint.url() <> "/"} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="scott" />
    <meta property="og:title" content={@page_title || "scott"} />
    <meta property="og:description" content={@meta_description || "Chat with an AI assistant about Scott's skills, experience, projects, and contact."} />
    <meta property="og:url" content={@canonical_url || AgentBackendWeb.Endpoint.url() <> "/"} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={@page_title || "scott"} />
    <meta name="twitter:description" content={@meta_description || "Chat with an AI assistant about Scott's skills, experience, projects, and contact."} />
    <meta name="theme-color" content="#09090b" />
    <link rel="icon" type="image/svg+xml" href={AgentBackendWeb.Endpoint.static_path("/images/favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <style><%= raw(app_css()) %></style>
    <script defer phx-track-static type="text/javascript" src={app_js_path()}></script>
  </head>
  <body class="h-full bg-zinc-950 text-zinc-200 font-mono antialiased">
    <%= @inner_content %>
  </body>
</html>
