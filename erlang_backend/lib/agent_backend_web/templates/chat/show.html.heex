
<div class="h-full flex flex-col" phx-hook="ChatHook">
  <!-- Sidebar -->
  <aside id="sidebar" class="w-80 bg-gray-900 border-r border-gray-800 flex flex-col hidden lg:flex <%= if !@show_sidebar, do: "lg:hidden" %>" style="z-index: 50;">
    <div class="p-4 border-b border-gray-800 flex items-center justify-between">
      <h1 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Agent</h1>
      <button phx-click="toggle_sidebar" class="lg:hidden p-2 text-gray-400 hover:text-white rounded-lg hover:bg-gray-800 transition-colors">
        <.icon name={:chevron_left} class="w-5 h-5" />
      </button>
    </div>

    <button phx-click="new_conversation" class="mx-4 mt-4 w-full flex items-center gap-2 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:border-gray-600 transition-colors">
      <.icon name={:plus} class="w-4 h-4" />
      <span>New Conversation</span>
    </button>

    <div class="flex-1 overflow-y-auto p-2 mt-4">
      <%= if @conversations == [] do %>
        <div class="px-4 py-8 text-center text-gray-500 text-sm">No conversations yet</div>
      <% else %>
        <div class="space-y-1">
          <%= for conv <- @conversations do %>
            <button 
              phx-click="select_conversation"
              phx-value-id={conv.id}
              class={"w-full text-left px-3 py-2 rounded-lg text-sm transition-colors flex items-center justify-between gap-2 "
                <> if @current_conversation && @current_conversation.id == conv.id, do: "bg-gray-800 border border-gray-700 text-white", else: "text-gray-300 hover:bg-gray-800 hover:text-white"}
            >
              <div class="flex-1 min-w-0">
                <p class="font-medium truncate"><%= conv.title %></p>
                <p class="text-xs text-gray-500 truncate mt-0.5"><%= conv.updated_at %></p>
              </div>
              <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100">
                <span class="text-xs text-gray-500 bg-gray-800 px-2 py-0.5 rounded"><%= conv.message_count %> msgs</span>
                <button 
                  phx-click="delete_conversation"
                  phx-value-id={conv.id}
                  class="p-1 text-gray-500 hover:text-red-400 rounded"
                  phx-event-stop="click"
                >
                  <.icon name={:trash} class="w-3.5 h-3.5" />
                </button>
              </div>
            </button>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="p-4 border-t border-gray-800">
      <button phx-click="open_system_prompt_modal" class="w-full flex items-center gap-2 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:border-gray-600 transition-colors">
        <.icon name={:settings} class="w-4 h-4" />
        <span>System Prompt</span>
      </button>
    </div>
  </aside>

  <!-- Mobile sidebar overlay -->
  <div 
    id="sidebar-overlay" 
    class="fixed inset-0 bg-black/50 z-40 lg:hidden <%= if @show_sidebar, do: "block", else: "hidden" %>" 
    phx-click="toggle_sidebar"
  ></div>

  <!-- Main Chat Area -->
  <main class="flex-1 flex flex-col lg:ml-0" id="main-content">
    <header class="px-6 py-4 border-b border-gray-800 bg-gray-900/50 backdrop-blur-sm sticky top-0 z-10">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500">
          <%= if @current_conversation do %>
            <%= @current_conversation.title %>
          <% else %>
            New Conversation
          <% end %>
        </h2>
        <div class="flex items-center gap-2">
          <button phx-click="open_system_prompt_modal" class="p-2 text-gray-400 hover:text-white rounded-lg hover:bg-gray-800 transition-colors">
            <.icon name={:settings} class="w-5 h-5" />
          </button>
          <button phx-click="toggle_sidebar" class="lg:hidden p-2 text-gray-400 hover:text-white rounded-lg hover:bg-gray-800 transition-colors">
            <.icon name={:menu} class="w-5 h-5" />
          </button>
        </div>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 space-y-6" id="messages-container" phx-update="ignore">
      <%= if @messages == [] && !@current_conversation do %>
        <!-- Welcome State -->
        <div class="flex flex-col items-center justify-center h-full min-h-[400px] text-center">
          <div class="w-16 h-16 rounded-2xl bg-gray-800 border border-gray-700 flex items-center justify-center mb-6">
            <.icon name={:terminal} class="w-8 h-8 text-gray-500" />
          </div>
          <h3 class="text-2xl font-medium text-gray-100 mb-2">Agent Interface</h3>
          <p class="text-gray-500 max-w-md mb-8">Ask me about skills, education, experience, projects, or anything else.</p>
          
          <div class="flex flex-wrap gap-2 justify-center max-w-2xl">
            <%= for suggestion <- @suggestions do %>
              <button 
                phx-click="send_message"
                phx-value-message={suggestion}
                class="px-4 py-2 bg-gray-800 border border-gray-700 rounded-full text-sm text-gray-300 hover:bg-gray-700 hover:border-gray-600 hover:text-white transition-colors"
              >
                <%= suggestion %>
              </button>
            <% end %>
          </div>
        </div>
      <% else %>
        <!-- Messages -->
        <div class="space-y-6 max-w-3xl mx-auto w-full" id="messages-list">
          <%= for {message, index} <- Enum.with_index(@messages) do %>
            <.message_bubble message={message} index={index} />
          <% end %>
          
          <!-- Loading indicator -->
          <%= if @is_loading do %>
            <div class="flex gap-3 justify-start">
              <.avatar type={:assistant} />
              <div class="bg-gray-800 border border-gray-700 rounded-2xl px-4 py-2">
                <div class="flex gap-1 items-center">
                  <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
                  <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
                  <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Input Form -->
    <form phx-submit="send_message" class="p-4 border-t border-gray-800 bg-gray-900/50 backdrop-blur-sm" id="input-form">
      <div class="flex gap-3 max-w-3xl mx-auto">
        <textarea
          phx-value="input"
          phx-change="update_input"
          placeholder={@current_conversation ? "Ask anything..." : "Start a new conversation..."}
          class="flex-1 bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100 placeholder-gray-500 resize-none focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 font-mono text-sm"
          rows="1"
          style="min-height: 48px; max-height: 200px;"
        ></textarea>
        <button 
          type="submit"
          class="w-12 h-12 bg-gray-800 border border-gray-700 rounded-xl flex items-center justify-center text-gray-300 hover:bg-gray-700 hover:border-gray-600 hover:text-white transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          disabled={@input == "" && !@is_loading}
        >
          <%= if @is_loading do %>
            <.icon name={:stop} class="w-5 h-5" />
          <% else %>
            <.icon name={:send} class="w-5 h-5" />
          <% end %>
        </button>
      </div>
    </form>
  </main>

  <!-- System Prompt Modal -->
  <%= if @show_system_prompt_modal do %>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80" phx-click="close_system_prompt_modal">
      <div class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-2xl max-h-[80vh] flex flex-col" phx-click="close_system_prompt_modal" phx-event-stop="click">
        <div class="p-4 border-b border-gray-700 flex items-center justify-between">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-400">System Prompt</h3>
          <button phx-click="close_system_prompt_modal" class="p-2 text-gray-400 hover:text-white rounded-lg hover:bg-gray-800 transition-colors">
            <.icon name={:x} class="w-5 h-5" />
          </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
          <textarea
            phx-value="system_prompt"
            phx-change="update_system_prompt"
            class="w-full h-96 bg-gray-950 border border-gray-700 rounded-lg px-4 py-3 text-gray-100 placeholder-gray-500 font-mono text-sm resize-none focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            placeholder="Enter system prompt..."
          ><%= @system_prompt %></textarea>
        </div>
        <div class="p-4 border-t border-gray-700 flex justify-end gap-3">
          <button phx-click="reset_system_prompt" class="px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:border-gray-600 transition-colors">
            Reset to Default
          </button>
          <button phx-click="save_system_prompt" class="px-4 py-2 bg-blue-600 rounded-lg text-sm font-medium text-white hover:bg-blue-500 transition-colors">
            Save & Close
          </button>
        </div>
      </div>
    </div>
  <% end %>
</div>
