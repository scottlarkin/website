<div
  id="chat-root"
  class="h-dvh overflow-hidden bg-zinc-950 text-zinc-200 flex flex-col font-mono"
>
  <div data-reconnect-banner class="hidden border-b border-amber-900/50 bg-amber-950/40 px-4 py-1.5 text-center text-xs text-amber-200/80">
    Reconnecting…
  </div>

  <!-- Minimal header -->
  <header class="sticky top-0 z-20 shrink-0 flex items-center justify-between border-b border-zinc-800/80 bg-zinc-950/95 px-4 py-3 backdrop-blur-sm header-accent">
    <button
      type="button"
      phx-click="new_chat"
      class="term-btn term-btn-lg -ml-1 text-zinc-400"
      aria-label="Home"
    >
      <span class="text-sm font-medium tracking-tight text-zinc-300">scott</span>
    </button>

    <div class="flex items-center gap-1.5">
      <%= if @chat_id do %>
        <button
          type="button"
          id="copy-link-btn"
          data-copy-link
          data-copy-url={AgentBackendWeb.Endpoint.url() <> "/c/#{@chat_id}"}
          class="btn-glow term-btn"
          title="Copy chat link"
        >
          <span class="btn-glow-fx" aria-hidden="true"></span>
          <span data-copy-label>share</span>
        </button>
      <% end %>

      <button
        phx-click="new_chat"
        id="new-chat-btn"
        class="btn-glow term-btn"
        title="New chat (⌘K)"
      >
        <span class="btn-glow-fx" aria-hidden="true"></span>
        <span>new</span>
      </button>
    </div>
  </header>

  <!-- Chat container -->
  <div class="flex-1 min-h-0 flex flex-col overflow-hidden max-w-2xl w-full mx-auto">
    <!-- Messages -->
    <div
      id="messages"
      class={"flex-1 min-h-0 overflow-y-auto px-4 py-6 space-y-4 scrollbar-chat" <> if(@messages == [], do: " empty-stage", else: "")}
      phx-hook="AutoScroll"
    >
      <%= if @messages == [] do %>
        <div
          id="suggestion-typewriter"
          phx-update="ignore"
          data-suggestion-typewriter
          data-suggestions={Jason.encode!(@typewriter_prompts)}
          class="flex h-full flex-col items-center justify-center text-center px-4 relative z-10"
        >
          <h2 class="text-xl font-semibold text-zinc-100 tracking-tight">Hi, I'm Scott.</h2>
          <p class="terminal-mono mt-3 max-w-sm text-sm text-zinc-500">
            <span class="text-zinc-600">&gt; </span><span data-typewriter></span><span data-cursor class="text-sky-400/90 animate-pulse">▌</span>
          </p>
          <p class="mt-2 max-w-sm text-xs text-zinc-600 leading-relaxed">
            I answer questions about my work — skills, projects, and how to reach me.
          </p>
        </div>
      <% else %>
        <%= for {message, idx} <- Enum.with_index(@messages) do %>
          <div
            id={"msg-#{idx}"}
            class={
              "group relative msg-enter term-line " <>
                cond do
                  message.role == "user" -> "term-line-user"
                  message_error?(message) -> "term-line-error"
                  true -> "term-line-agent"
                end
            }
          >
            <%= if ts = format_timestamp(message[:timestamp] || message["timestamp"] || "") do %>
              <time
                datetime={message[:timestamp] || message["timestamp"]}
                class="absolute -top-4 left-2 whitespace-nowrap text-[10px] text-zinc-600 opacity-0 transition-opacity group-hover:opacity-100"
              >
                <%= ts %>
              </time>
            <% end %>

            <%= if message.role == "user" do %>
              <div class="term-row">
                <span class="term-who term-who-user">you</span>
                <span class="term-prompt term-prompt-user" aria-hidden="true">$</span>
                <div class="term-body-user"><%= message.content %></div>
              </div>
            <% else %>
              <%!-- assistant --%>
              <div class="term-row">
                <span class={"term-who " <> if(message_error?(message), do: "term-who-error", else: "term-who-agent")}>
                  scott
                </span>
                <span
                  class={"term-prompt " <> if(message_error?(message), do: "text-rose-400/80", else: "term-prompt-agent")}
                  aria-hidden="true"
                >&gt;</span>
                <div class="term-body-agent">
                  <%= if message_error?(message) do %>
                    <div class="space-y-1 text-rose-200/90">
                      <p><%= user_facing_error_message() %></p>
                      <p class="text-[11px] text-zinc-600"><%= user_facing_error_hint() %></p>
                      <div class="flex flex-wrap items-center gap-1 pt-1">
                        <%= if not @is_loading and idx == length(@messages) - 1 do %>
                          <button
                            type="button"
                            phx-click="reload_message"
                            phx-value-index={idx}
                            class="term-btn term-btn-danger term-btn-lg"
                          >
                            retry
                          </button>
                        <% end %>
                        <%= if @chat_id && message_has_content?(message) do %>
                          <a
                            href={"/branch/#{@chat_id}/#{idx}"}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="term-btn term-btn-lg"
                            title="Open a new chat forked from here"
                          >
                            branch
                          </a>
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div id={"assistant-body-#{idx}"} phx-hook="RevisionCrossfade" class="relative">
                      <%= if idx == length(@messages) - 1 and @held_draft do %>
                        <div
                          data-held-draft
                          class="term-prose opacity-50 transition-opacity duration-300"
                        >
                          <%= render_markdown(@held_draft) %>
                          <span class="term-cursor term-cursor-grey" aria-hidden="true">▌</span>
                        </div>
                        <p class="mt-1 text-xs text-zinc-600"><%= agent_status_label(:revising) %></p>
                      <% else %>
                        <%= if message.content == "" and idx == length(@messages) - 1 and @is_loading do %>
                          <div id={"thinking-indicator-#{idx}"} class="text-zinc-500">
                            <span><%= @thinking_line || "Checking notes" %></span><span class="term-cursor term-cursor-grey" aria-hidden="true">▌</span>
                          </div>
                        <% else %>
                          <%= if idx == length(@messages) - 1 and @is_loading and @agent_status == :generating do %>
                            <div data-live-content class="whitespace-pre-wrap text-zinc-300">
                              <%= message.content %><span class="term-cursor term-cursor-grey" aria-hidden="true">▌</span>
                            </div>
                          <% else %>
                            <div data-live-content class="term-prose">
                              <%= render_markdown(message.content) %>
                            </div>
                            <%= if message_has_content?(message) and not (@is_loading and idx == length(@messages) - 1) do %>
                              <div class="mt-1 flex flex-wrap items-center gap-1">
                                <button
                                  type="button"
                                  data-copy-message
                                  data-copy-text={message.content}
                                  class="term-btn opacity-0 transition-opacity group-hover:opacity-100"
                                  title="Copy reply"
                                >
                                  <span data-copy-label>copy</span>
                                </button>
                                <%= if @chat_id do %>
                                  <a
                                    href={"/branch/#{@chat_id}/#{idx}"}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="term-btn opacity-0 transition-opacity group-hover:opacity-100"
                                    title="Open a new chat forked from here"
                                  >
                                    branch
                                  </a>
                                <% end %>
                                <%= if idx == length(@messages) - 1 and not @is_loading do %>
                                  <button
                                    type="button"
                                    phx-click="reload_message"
                                    phx-value-index={idx}
                                    class="term-btn opacity-0 transition-opacity group-hover:opacity-100"
                                    title="Regenerate this reply"
                                  >
                                    reload
                                  </button>
                                <% end %>
                              </div>
                            <% end %>
                            <%= if idx == length(@messages) - 1 and @validation_badge and not @is_loading do %>
                              <div class="mt-1 flex items-center gap-1.5 text-[10px] text-zinc-600">
                                <span class="text-sky-500/70">✓</span>
                                <span>double-checked</span>
                                <button
                                  type="button"
                                  phx-click="dismiss_validation_badge"
                                  class="term-btn"
                                  aria-label="Dismiss"
                                >
                                  x
                                </button>
                              </div>
                            <% end %>
                            <%= if idx == length(@messages) - 1 and @is_loading and agent_status_label(@agent_status) do %>
                              <p class="mt-1 text-xs text-zinc-600">
                                <%= agent_status_label(@agent_status) %><span class="term-cursor term-cursor-grey" aria-hidden="true">▌</span>
                              </p>
                            <% end %>
                          <% end %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Input -->
    <div class="chat-composer shrink-0 bg-zinc-950 px-4 pb-3 pt-1">
      <form id="chat-form" phx-hook="ChatForm" phx-submit="send_message" class="flex items-center gap-2">
        <label class="terminal-mono flex min-w-0 flex-1 items-center gap-2 text-zinc-200">
          <span class="terminal-prompt-char select-none text-zinc-600" aria-hidden="true">&gt;</span>
          <input
            id="chat-input"
            type="text"
            name="message"
            value={@input}
            placeholder={@input_placeholder}
            class="terminal-input min-w-0 flex-1 border-0 bg-transparent py-0.5 text-zinc-200 placeholder:text-zinc-600 focus:outline-none focus:ring-0"
            autocomplete="off"
            spellcheck="false"
            enterkeyhint="done"
            inputmode="text"
            phx-change="update_input"
            phx-debounce="300"
          />
        </label>
        <%= if @is_loading do %>
          <button
            type="button"
            phx-click="cancel_run"
            id="cancel-run-btn"
            class="btn-glow btn-glow-danger term-btn term-btn-danger term-btn-icon shrink-0"
            aria-label="Stop"
            title="Stop generating"
          >
            <span class="btn-glow-fx" aria-hidden="true"></span>
            <span aria-hidden="true">■</span>
          </button>
        <% else %>
          <button
            type="submit"
            id="send-btn"
            class="mobile-only-send btn-glow term-btn term-btn-lg shrink-0"
            aria-label="Send"
            title="Send"
          >
            <span class="btn-glow-fx" aria-hidden="true"></span>
            <span>send</span>
          </button>
        <% end %>
      </form>

      <!-- Minimal suggestions (only when empty) -->
      <%= if @messages == [] and not @is_loading and @suggestions do %>
        <div class="mt-2.5 flex flex-wrap justify-center gap-1.5 px-1">
          <%= for s <- @suggestions do %>
            <button
              type="button"
              phx-click="send_suggestion"
              phx-value-message={s.prompt}
              class="btn-glow term-btn term-btn-lg"
            >
              <span class="btn-glow-fx" aria-hidden="true"></span>
              <span><%= s.label %></span>
            </button>
          <% end %>
        </div>
      <% end %>

      <p class="mt-2.5 px-1 text-center text-[10px] tracking-wide text-zinc-700">
        LiveView · streaming · fact-checked
      </p>
    </div>
  </div>
</div>
