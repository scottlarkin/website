<div
  id="chat-root"
  class="h-dvh overflow-hidden bg-zinc-950 text-zinc-200 flex flex-col font-sans"
>
  <div data-reconnect-banner class="hidden border-b border-amber-900/50 bg-amber-950/40 px-4 py-1.5 text-center text-xs text-amber-200/80">
    Reconnecting…
  </div>

  <!-- Minimal header -->
  <header class="sticky top-0 z-20 shrink-0 flex items-center justify-between border-b border-zinc-800/80 bg-zinc-950/95 px-4 py-3 backdrop-blur-sm header-accent">
    <button
      type="button"
      phx-click="new_chat"
      class="flex items-center gap-2 rounded-md px-1 py-0.5 -ml-1 text-left transition-colors hover:bg-zinc-900 hover:text-zinc-100"
      aria-label="Home"
    >
      <div class="w-6 h-6 rounded bg-white/10 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <span class="text-sm font-medium tracking-tight text-zinc-300">Scott</span>
    </button>

    <div class="flex items-center gap-1.5">
      <%= if @chat_id do %>
        <button
          type="button"
          id="copy-link-btn"
          data-copy-link
          data-copy-url={AgentBackendWeb.Endpoint.url() <> "/c/#{@chat_id}"}
          class="flex items-center gap-1 rounded-full border border-zinc-800 bg-zinc-900 px-2 py-0.5 text-[10px] font-medium text-zinc-500 transition-colors hover:border-sky-500/30 hover:bg-zinc-800 hover:text-sky-200/90"
          title="Copy chat link"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          <span data-copy-label>Share</span>
        </button>
      <% end %>

      <button
        phx-click="new_chat"
        id="new-chat-btn"
        class="flex items-center gap-1 rounded-full border border-zinc-800 bg-zinc-900 px-2 py-0.5 text-[10px] font-medium text-zinc-500 transition-colors hover:border-sky-500/30 hover:bg-zinc-800 hover:text-sky-200/90"
        title="New chat (⌘K)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        <span>New</span>
      </button>
    </div>
  </header>

  <!-- Chat container -->
  <div class="flex-1 min-h-0 flex flex-col overflow-hidden max-w-2xl w-full mx-auto">
    <!-- Messages -->
    <div
      id="messages"
      class={"flex-1 min-h-0 overflow-y-auto px-4 py-6 space-y-5 scrollbar-chat" <> if(@messages == [], do: " empty-stage", else: "")}
      phx-hook="AutoScroll"
    >
      <%= if @messages == [] do %>
        <div
          id="suggestion-typewriter"
          phx-update="ignore"
          data-suggestion-typewriter
          data-suggestions={Jason.encode!(@typewriter_prompts)}
          class="flex h-full flex-col items-center justify-center text-center px-4 relative z-10"
        >
          <h2 class="text-xl font-semibold text-zinc-100 tracking-tight">Hi, I'm Scott.</h2>
          <p class="mt-3 max-w-sm font-mono text-sm text-zinc-500">
            <span class="text-zinc-600">&gt; </span><span data-typewriter></span><span data-cursor class="text-sky-400/90 animate-pulse">▌</span>
          </p>
          <p class="mt-2 max-w-sm text-xs text-zinc-600 leading-relaxed">
            I answer questions about my work — skills, projects, and how to reach me.
          </p>
        </div>
      <% else %>
        <%= for {message, idx} <- Enum.with_index(@messages) do %>
          <div id={"msg-#{idx}"} class={"flex msg-enter " <> if message.role == "user", do: "justify-end", else: "justify-start"}>
            <div class={"group relative max-w-[80%] " <> if message.role == "user", do: "", else: ""}>
              <%= if ts = format_timestamp(message[:timestamp] || message["timestamp"] || "") do %>
                <time
                  datetime={message[:timestamp] || message["timestamp"]}
                  class={"absolute -top-5 whitespace-nowrap text-[10px] text-zinc-600 opacity-0 transition-opacity group-hover:opacity-100 " <>
                    if message.role == "user", do: "right-0", else: "left-0"}
                >
                  <%= ts %>
                </time>
              <% end %>
              <div class={"rounded-2xl px-4 py-2.5 text-sm leading-relaxed " <>
                cond do
                  message.role == "user" ->
                    "bg-white text-zinc-950"

                  message_error?(message) ->
                    "bg-zinc-900/80 border border-rose-900/50 text-zinc-300"

                  true ->
                    "bg-zinc-900 border border-zinc-800 text-zinc-200"
                end}>
                <%= if message.role == "assistant" do %>
                  <%= if message_error?(message) do %>
                    <div class="space-y-2">
                      <p class="text-sm text-zinc-300"><%= user_facing_error_message() %></p>
                      <p class="text-[11px] text-zinc-600"><%= user_facing_error_hint() %></p>
                      <%= if idx == length(@messages) - 1 and not @is_loading do %>
                        <button
                          type="button"
                          phx-click="retry_last"
                          class="mt-1 inline-flex items-center gap-1.5 rounded-full border border-rose-900/40 bg-rose-950/30 px-3 py-1 text-xs font-medium text-rose-200/90 transition-colors hover:bg-rose-950/50 hover:text-rose-100"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                          </svg>
                          Try again
                        </button>
                      <% end %>
                    </div>
                  <% else %>
                    <div id={"assistant-body-#{idx}"} phx-hook="RevisionCrossfade" class="relative">
                      <%= if idx == length(@messages) - 1 and @held_draft do %>
                        <div
                          data-held-draft
                          class="prose prose-invert prose-sm max-w-none opacity-50 transition-opacity duration-300 prose-p:my-1 prose-ul:my-1 prose-ol:my-1 prose-pre:my-2 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:bg-zinc-800 prose-code:before:content-[''] prose-code:after:content-['']"
                        >
                          <%= render_markdown(@held_draft) %>
                        </div>
                        <p class="mt-2 text-xs text-zinc-500 animate-pulse"><%= agent_status_label(:revising) %></p>
                      <% else %>
                        <%= if message.content == "" and idx == length(@messages) - 1 and @is_loading do %>
                          <div
                            id={"thinking-indicator-#{idx}"}
                            class="flex items-center gap-1.5 text-zinc-400"
                          >
                            <span><%= @thinking_line || "Checking notes" %></span>
                            <span class="inline-flex items-center gap-px">
                              <span class="inline-block w-1 h-1 bg-current rounded-full animate-bounce [animation-delay:-0.2s]"></span>
                              <span class="inline-block w-1 h-1 bg-current rounded-full animate-bounce [animation-delay:-0.1s]"></span>
                              <span class="inline-block w-1 h-1 bg-current rounded-full animate-bounce"></span>
                            </span>
                          </div>
                        <% else %>
                          <%= if idx == length(@messages) - 1 and @is_loading and @agent_status == :generating do %>
                            <div data-live-content class="whitespace-pre-wrap"><%= message.content %></div>
                          <% else %>
                            <div data-live-content class="prose prose-invert prose-sm max-w-none prose-p:my-1 prose-ul:my-1 prose-ol:my-1 prose-pre:my-2 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:bg-zinc-800 prose-code:before:content-[''] prose-code:after:content-['']">
                              <%= render_markdown(message.content) %>
                            </div>
                            <%= if message.content != "" and not @is_loading do %>
                              <button
                                type="button"
                                data-copy-message
                                data-copy-text={message.content}
                                class="mt-2 inline-flex items-center gap-1 text-[10px] text-zinc-600 opacity-0 transition-opacity group-hover:opacity-100 hover:text-zinc-400"
                                title="Copy reply"
                              >
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                </svg>
                                <span data-copy-label>Copy</span>
                              </button>
                            <% end %>
                            <%= if idx == length(@messages) - 1 and @validation_badge and not @is_loading do %>
                              <div class="mt-2 flex items-center gap-1.5 text-[10px] text-zinc-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0 text-sky-500/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                </svg>
                                <span>Double-checked against my notes</span>
                                <button
                                  type="button"
                                  phx-click="dismiss_validation_badge"
                                  class="ml-0.5 rounded px-0.5 text-zinc-500 hover:text-zinc-300"
                                  aria-label="Dismiss"
                                >
                                  ×
                                </button>
                              </div>
                            <% end %>
                            <%= if idx == length(@messages) - 1 and @is_loading and agent_status_label(@agent_status) do %>
                              <p class="mt-2 text-xs text-zinc-500 animate-pulse"><%= agent_status_label(@agent_status) %></p>
                            <% end %>
                          <% end %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                <% else %>
                  <div class="whitespace-pre-wrap"><%= message.content %></div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Input -->
    <div class="shrink-0 border-t border-zinc-800 bg-zinc-950 p-3">
      <form id="chat-form" phx-hook="ChatForm" phx-submit="send_message" class="flex items-center gap-2">
        <input
          id="chat-input"
          type="text"
          name="message"
          value={@input}
          placeholder={@input_placeholder}
          class="flex-1 bg-zinc-900 border border-zinc-800 rounded-full px-4 py-2.5 text-sm placeholder:text-zinc-500 transition-colors hover:border-sky-500/30 hover:bg-zinc-800 focus:border-sky-500/40 focus:ring-1 focus:ring-sky-500/20 focus:outline-none"
          autocomplete="off"
          phx-change="update_input"
          phx-debounce="300"
        />
        <button
          type="submit"
          disabled={@is_loading}
          class="flex h-8 w-8 items-center justify-center rounded-full bg-white text-zinc-950 disabled:bg-zinc-800 disabled:text-zinc-600 transition-all hover:bg-sky-50 active:scale-95 send-btn"
          aria-label="Send"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
      </form>

      <!-- Minimal suggestions (only when empty) -->
      <%= if @messages == [] and not @is_loading and @suggestions do %>
        <div class="mt-2.5 flex flex-wrap justify-center gap-1.5 px-1">
          <%= for s <- @suggestions do %>
            <button
              type="button"
              phx-click="send_suggestion"
              phx-value-message={s.prompt}
              class="text-xs rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1 text-zinc-400 transition-colors hover:border-sky-500/30 hover:bg-zinc-800 hover:text-sky-200/90"
            >
              <%= s.label %>
            </button>
          <% end %>
        </div>
      <% end %>

      <p class="mt-2.5 px-1 text-center text-[10px] tracking-wide text-zinc-700">
        LiveView · streaming · fact-checked
      </p>
    </div>
  </div>
</div>
