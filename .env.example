# Agent Backend Environment Variables
# Copy to .env and fill in your values

# Phoenix
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
LIVE_VIEW_SALT=generate-with-mix-phx-gen-secret
SYSTEM_PROMPT=You are a personal AI agent representing the person whose portfolio this is. Answer questions about their skills, education, experience, projects, and contact info using the available tools.
PHX_HOST=localhost

# LLM API (OpenRouter or OpenAI compatible)
OPENROUTER_KEY=your-api-key
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free